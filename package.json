{
  "name": "next-swr",
  "description": "Revalidate stale data in Next.js",
  "version": "0.2.0-canary.0",
  "license": "MIT",
  "author": "aprendendofelipe",
  "repository": "aprendendofelipe/next-swr",
  "keywords": [
    "cache",
    "fetch",
    "next",
    "request",
    "revalidate",
    "swr"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.js"
    }
  },
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "dts build --entry ./src/index.ts --entry ./src/middleware/index.ts --format cjs",
    "commit": "cz",
    "lint": "npm run lint:prettier",
    "lint:fix": "eslint --fix && prettier --write .",
    "lint:prettier": "prettier --check .",
    "pre-commit": "lint-staged",
    "prepare": "husky install && npm run build",
    "size": "size-limit",
    "start": "dts watch",
    "test": "jest",
    "test:integration": "playwright test",
    "test:ui": "playwright test --ui",
    "test:watch": "jest --watch",
    "web-server": "npm run build && npm run web-server:build && npm run web-server:start",
    "web-server:build": "next build ./tests/utils/server",
    "web-server:dev": "next dev ./tests/utils/server",
    "web-server:start": "next start ./tests/utils/server"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "npm run lint:fix"
    ]
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "prettier": {
    "endOfLine": "auto",
    "printWidth": 120,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@commitlint/cli": "17.6.1",
    "@commitlint/config-conventional": "17.6.1",
    "@playwright/test": "1.35.1",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "14.0.0",
    "@tsconfig/recommended": "1.0.2",
    "@tsconfig/vite-react": "1.0.1",
    "@types/react": "18.0.35",
    "@types/react-dom": "18.0.11",
    "@typescript-eslint/eslint-plugin": "5.60.0",
    "@typescript-eslint/parser": "5.60.0",
    "dts-cli": "2.0.0",
    "eslint": "8.43.0",
    "eslint-config-standard-with-typescript": "35.0.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-n": "15.7.0",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-react": "7.32.2",
    "husky": "8.0.3",
    "jest": "29.5.0",
    "jest-environment-jsdom": "29.5.0",
    "lint-staged": "13.2.1",
    "next": "13.4.6",
    "next-router-mock": "0.9.6",
    "prettier": "2.8.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tslib": "2.5.0",
    "typescript": "5.1.3"
  }
}
